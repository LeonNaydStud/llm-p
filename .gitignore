cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# Database
*.db
*.sqlite
*.sqlite3

# Environment
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# UV
uv.lock

# screenshots/

# Jupyter
.ipynb_checkpoints/

# PyCharm
.idea/
EOF